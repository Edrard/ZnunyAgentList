<?xml version="1.0" encoding="utf-8" ?>
<otrs_package version="1.1">
    <Name>ZnunyAgentList</Name>
    <Version>1.0.0</Version>
    <Framework>6.5.x</Framework>
    <Vendor>Vamark</Vendor>
    <URL>https://github.com/vamark/ZnunyAgentList</URL>
    <License>GPL-3.0-or-later</License>
    <Description Lang="en">Provides a secure, read-only GenericInterface operation for listing active Znuny agents.</Description>
    <Filelist>
        <File Permission="644" Location="Kernel/GenericInterface/Operation/User/AgentList.pm" />
        <File Permission="644" Location="Kernel/Config/Files/XML/ZnunyAgentList.xml" />
    </Filelist>
</otrs_package>
